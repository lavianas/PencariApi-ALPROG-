<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PencariApi.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#0D2538"
    Title="Login">

    <Grid>

        <Frame
            WidthRequest="430"
            Padding="34"
            CornerRadius="26"
            HasShadow="True"
            BackgroundColor="White"
            HorizontalOptions="Center"
            VerticalOptions="Center">

            <VerticalStackLayout Spacing="22">

                <Frame
                    WidthRequest="86"
                    HeightRequest="86"
                    CornerRadius="24"
                    Padding="0"
                    HasShadow="False"
                    BackgroundColor="#FF5A14"
                    HorizontalOptions="Center">

                    <Label
                        Text="🔥"
                        FontSize="44"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Frame>

                <Label
                    Text="PencariApi OPTIMA"
                    FontSize="26"
                    FontAttributes="Bold"
                    TextColor="#101828"
                    HorizontalOptions="Center" />

                <Label
                    Text="Login Operator"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="#101828"
                    HorizontalOptions="Center" />

                <Label
                    Text="Masukkan username dan password dulu"
                    FontSize="13"
                    TextColor="#667085"
                    HorizontalOptions="Center" />

                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Username"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="#344054" />

                    <Frame
                        CornerRadius="14"
                        Padding="14,0"
                        HasShadow="False"
                        BorderColor="#D0D5DD"
                        BackgroundColor="#F9FAFB">

                        <Entry
                            x:Name="UsernameEntry"
                            Placeholder="Masukkan username"
                            TextColor="#101828"
                            PlaceholderColor="#98A2B3"
                            BackgroundColor="Transparent" />
                    </Frame>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Password"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="#344054" />

                    <Frame
                        CornerRadius="14"
                        Padding="14,0"
                        HasShadow="False"
                        BorderColor="#D0D5DD"
                        BackgroundColor="#F9FAFB">

                        <Entry
                            x:Name="PasswordEntry"
                            Placeholder="Masukkan password"
                            IsPassword="True"
                            TextColor="#101828"
                            PlaceholderColor="#98A2B3"
                            BackgroundColor="Transparent" />
                    </Frame>
                </VerticalStackLayout>

                <Label
                    x:Name="ErrorLabel"
                    Text=""
                    FontSize="13"
                    TextColor="#EF4444"
                    HorizontalOptions="Center" />

                <Button
                    Text="LOGIN"
                    HeightRequest="54"
                    CornerRadius="14"
                    BackgroundColor="#FF5A14"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    Clicked="OnLoginClicked" />

                <Label
                    Text="Demo: admin / 12345"
                    FontSize="12"
                    TextColor="#98A2B3"
                    HorizontalOptions="Center" />

            </VerticalStackLayout>
        </Frame>

    </Grid>
</ContentPage>