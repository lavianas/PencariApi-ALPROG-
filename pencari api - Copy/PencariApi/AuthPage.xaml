<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PencariApi.AuthPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    BackgroundColor="#EEF2F7"
    Title="PencariApi">

    <Grid ColumnDefinitions="1*,1.25*">

        <!-- ================= PANEL KIRI ================= -->
        <Grid Grid.Column="0" Padding="45" BackgroundColor="#0F2742">

            <VerticalStackLayout Spacing="24" VerticalOptions="Center">

                <Frame
                    WidthRequest="95"
                    HeightRequest="95"
                    CornerRadius="25"
                    Padding="10"
                    HasShadow="False"
                    BackgroundColor="#17365D">

                    <Image
                        Source="fire_logo.png"
                        Aspect="AspectFit" />
                </Frame>

                <Label
                    Text="PencariApi OPTIMA"
                    FontSize="34"
                    FontAttributes="Bold"
                    TextColor="White" />

                <Label
                    Text="Optimasi Rute Pemadam Api via Kamera IoT dan Algoritma Genetika"
                    FontSize="22"
                    TextColor="#DCEBFF"
                    LineHeight="1.3" />

                <Label
                    Text="Smart Fire Response System"
                    FontSize="16"
                    TextColor="#7DB4FF" />

                <Grid HeightRequest="300" Margin="0,30,0,0">

                    <Frame
                        WidthRequest="90"
                        HeightRequest="90"
                        CornerRadius="45"
                        Padding="0"
                        HasShadow="False"
                        BackgroundColor="#1B3553"
                        BorderColor="#7EA8D9"
                        HorizontalOptions="Start"
                        VerticalOptions="Start">

                        <Label
                            Text="🔥"
                            FontSize="45"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Frame>

                    <Frame
                        WidthRequest="85"
                        HeightRequest="85"
                        CornerRadius="22"
                        Padding="0"
                        HasShadow="False"
                        BackgroundColor="#203A59"
                        BorderColor="#7EA8D9"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">

                        <Label
                            Text="📷"
                            FontSize="38"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Frame>

                    <Frame
                        WidthRequest="90"
                        HeightRequest="90"
                        CornerRadius="22"
                        Padding="0"
                        HasShadow="False"
                        BackgroundColor="#203A59"
                        BorderColor="#7EA8D9"
                        HorizontalOptions="End"
                        VerticalOptions="End">

                        <Label
                            Text="🚒"
                            FontSize="40"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Frame>

                    <Label
                        Text="📍"
                        FontSize="55"
                        HorizontalOptions="Center"
                        VerticalOptions="End"
                        Margin="0,0,60,35" />

                </Grid>

            </VerticalStackLayout>
        </Grid>

        <!-- ================= PANEL KANAN ================= -->
        <Grid Grid.Column="1" Padding="35">

            <Frame
                Padding="30"
                CornerRadius="25"
                HasShadow="False"
                BackgroundColor="White"
                BorderColor="#E7ECF3"
                WidthRequest="700"
                HorizontalOptions="Center"
                VerticalOptions="Center">

                <ScrollView>
                    <VerticalStackLayout Spacing="18">

                        <!-- ROLE -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                            <Button
                                x:Name="BtnAdmin"
                                Text="Admin"
                                HeightRequest="55"
                                CornerRadius="14"
                                BorderColor="#FFB067"
                                BorderWidth="1"
                                BackgroundColor="#FFF4EB"
                                TextColor="#FF6A00"
                                FontAttributes="Bold"
                                Clicked="OnAdminClicked" />

                            <Button
                                x:Name="BtnUser"
                                Grid.Column="1"
                                Text="User"
                                HeightRequest="55"
                                CornerRadius="14"
                                BorderColor="#D7DFEA"
                                BorderWidth="1"
                                BackgroundColor="White"
                                TextColor="#324B72"
                                FontAttributes="Bold"
                                Clicked="OnUserClicked" />

                        </Grid>

                        <!-- TITLE -->
                        <VerticalStackLayout Spacing="5" Margin="0,10,0,0">

                            <Label
                                x:Name="TitleLabel"
                                Text="Login Admin"
                                FontSize="34"
                                FontAttributes="Bold"
                                TextColor="#17365D" />

                            <Label
                                x:Name="SubtitleLabel"
                                Text="Masuk untuk mengakses dashboard dan mengelola sistem."
                                FontSize="14"
                                TextColor="#6E7F99" />

                        </VerticalStackLayout>

                        <!-- ================= LOGIN SECTION ================= -->
                        <VerticalStackLayout
                            x:Name="LoginSection"
                            Spacing="16"
                            Margin="0,10,0,0">

                            <Frame
                                CornerRadius="14"
                                Padding="16,8"
                                HasShadow="False"
                                BorderColor="#DCE4EF"
                                BackgroundColor="White">

                                <Entry
                                    x:Name="LoginUsernameEntry"
                                    Placeholder="Username"
                                    PlaceholderColor="#8A9AB3"
                                    TextColor="#1F2937"
                                    BackgroundColor="Transparent" />

                            </Frame>

                            <Frame
                                CornerRadius="14"
                                Padding="16,8"
                                HasShadow="False"
                                BorderColor="#DCE4EF"
                                BackgroundColor="White">

                                <Entry
                                    x:Name="LoginPasswordEntry"
                                    Placeholder="Password"
                                    IsPassword="True"
                                    PlaceholderColor="#8A9AB3"
                                    TextColor="#1F2937"
                                    BackgroundColor="Transparent" />

                            </Frame>

                            <Grid ColumnDefinitions="Auto,*,Auto">

                                <CheckBox
                                    x:Name="RememberCheckBox"
                                    Color="#FF6A00" />

                                <Label
                                    Grid.Column="1"
                                    Text="Ingat saya"
                                    VerticalOptions="Center"
                                    FontSize="13"
                                    TextColor="#53657F" />

                                <Button
                                    Grid.Column="2"
                                    Text="Lupa Password?"
                                    BackgroundColor="Transparent"
                                    TextColor="#2563EB"
                                    FontSize="13"
                                    Padding="0"
                                    Clicked="OnForgotPasswordClicked" />

                            </Grid>

                            <Label
                                x:Name="LoginErrorLabel"
                                Text=""
                                TextColor="#EF4444"
                                FontSize="13" />

                            <Button
                                x:Name="LoginButton"
                                Text="Masuk sebagai Admin"
                                HeightRequest="56"
                                CornerRadius="14"
                                BackgroundColor="#FF6A00"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="17"
                                Clicked="OnLoginClicked" />

                            <Grid ColumnDefinitions="*,Auto,*" Margin="0,8,0,0">

                                <BoxView
                                    HeightRequest="1"
                                    BackgroundColor="#E5EAF2"
                                    VerticalOptions="Center" />

                                <Label
                                    Grid.Column="1"
                                    Text="atau"
                                    Margin="10,0"
                                    TextColor="#9AA7BA" />

                                <BoxView
                                    Grid.Column="2"
                                    HeightRequest="1"
                                    BackgroundColor="#E5EAF2"
                                    VerticalOptions="Center" />

                            </Grid>

                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">

                                <Label
                                    Text="Belum punya akun?"
                                    FontSize="14"
                                    TextColor="#60708A" />

                                <Button
                                    Text="Registrasi"
                                    BackgroundColor="Transparent"
                                    TextColor="#2563EB"
                                    FontSize="14"
                                    Padding="0"
                                    Clicked="OnOpenRegisterClicked" />

                            </HorizontalStackLayout>

                        </VerticalStackLayout>

                        <!-- ================= REGISTER SECTION ================= -->
                        <VerticalStackLayout
                            x:Name="RegisterSection"
                            IsVisible="False"
                            Spacing="14"
                            Margin="0,10,0,0">

                            <Frame
                                CornerRadius="14"
                                Padding="16,8"
                                HasShadow="False"
                                BorderColor="#DCE4EF"
                                BackgroundColor="White">

                                <Entry
                                    x:Name="RegisterFullNameEntry"
                                    Placeholder="Nama Lengkap"
                                    PlaceholderColor="#8A9AB3"
                                    TextColor="#1F2937"
                                    BackgroundColor="Transparent" />

                            </Frame>

                            <Frame
                                CornerRadius="14"
                                Padding="16,8"
                                HasShadow="False"
                                BorderColor="#DCE4EF"
                                BackgroundColor="White">

                                <Entry
                                    x:Name="RegisterEmailEntry"
                                    Placeholder="Email"
                                    Keyboard="Email"
                                    PlaceholderColor="#8A9AB3"
                                    TextColor="#1F2937"
                                    BackgroundColor="Transparent" />

                            </Frame>

                            <Frame
                                CornerRadius="14"
                                Padding="16,8"
                                HasShadow="False"
                                BorderColor="#DCE4EF"
                                BackgroundColor="White">

                                <Entry
                                    x:Name="RegisterUsernameEntry"
                                    Placeholder="Username"
                                    PlaceholderColor="#8A9AB3"
                                    TextColor="#1F2937"
                                    BackgroundColor="Transparent" />

                            </Frame>

                            <Frame
                                CornerRadius="14"
                                Padding="16,8"
                                HasShadow="False"
                                BorderColor="#DCE4EF"
                                BackgroundColor="White">

                                <Entry
                                    x:Name="RegisterPasswordEntry"
                                    Placeholder="Password"
                                    IsPassword="True"
                                    PlaceholderColor="#8A9AB3"
                                    TextColor="#1F2937"
                                    BackgroundColor="Transparent" />

                            </Frame>

                            <Frame
                                CornerRadius="14"
                                Padding="16,8"
                                HasShadow="False"
                                BorderColor="#DCE4EF"
                                BackgroundColor="White">

                                <Entry
                                    x:Name="RegisterConfirmPasswordEntry"
                                    Placeholder="Konfirmasi Password"
                                    IsPassword="True"
                                    PlaceholderColor="#8A9AB3"
                                    TextColor="#1F2937"
                                    BackgroundColor="Transparent" />

                            </Frame>

                            <!-- KAMERA LIVE REGISTRASI -->
                            <Frame
                                CornerRadius="14"
                                Padding="16"
                                HasShadow="False"
                                BorderColor="#DCE4EF"
                                BackgroundColor="#FAFBFD">

                                <VerticalStackLayout Spacing="12">

                                    <Label
                                        Text="Foto Wajah untuk Verifikasi"
                                        FontAttributes="Bold"
                                        TextColor="#17365D"
                                        FontSize="14" />

                                    <Label
                                        Text="Kamera live akan langsung menyala saat masuk halaman registrasi. Tekan tombol di bawah untuk mengambil 15 sampel wajah."
                                        FontSize="12"
                                        TextColor="#6E7F99" />

                                    <Frame
                                        Padding="0"
                                        HeightRequest="220"
                                        CornerRadius="12"
                                        IsClippedToBounds="True"
                                        HasShadow="False"
                                        BorderColor="#DCE4EF"
                                        BackgroundColor="#111827">

                                        <toolkit:CameraView
                                            x:Name="RegisterCamera"
                                            HorizontalOptions="Fill"
                                            VerticalOptions="Fill"
                                            MediaCaptured="OnRegisterCameraMediaCaptured"
                                            MediaCaptureFailed="OnRegisterCameraMediaCaptureFailed" />

                                    </Frame>

                                    <Button
                                        x:Name="TakeRegisterPhotoButton"
                                        Text="Ambil 15 Sampel Foto Wajah"
                                        HeightRequest="48"
                                        CornerRadius="12"
                                        BackgroundColor="#0F2742"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        Clicked="OnTakeRegisterPhotoClicked" />

                                    <Frame
                                        Padding="0"
                                        HeightRequest="95"
                                        CornerRadius="12"
                                        HasShadow="False"
                                        BorderColor="#DCE4EF"
                                        BackgroundColor="#EEF2F7">

                                        <Image
                                            x:Name="RegisterPhotoPreview"
                                            Aspect="AspectFill" />

                                    </Frame>

                                    <Label
                                        x:Name="RegisterPhotoStatusLabel"
                                        Text="Kamera registrasi sedang disiapkan. Belum ada sampel wajah tersimpan."
                                        FontSize="13"
                                        TextColor="#6E7F99" />

                                </VerticalStackLayout>

                            </Frame>

                            <Grid ColumnDefinitions="Auto,*">

                                <CheckBox
                                    x:Name="TermsCheckBox"
                                    Color="#FF6A00" />

                                <Label
                                    Grid.Column="1"
                                    Text="Saya setuju dengan syarat dan ketentuan"
                                    VerticalOptions="Center"
                                    TextColor="#53657F"
                                    FontSize="13" />

                            </Grid>

                            <Label
                                x:Name="RegisterErrorLabel"
                                Text=""
                                TextColor="#EF4444"
                                FontSize="13" />

                            <Button
                                x:Name="RegisterButton"
                                Text="Daftar sebagai Admin"
                                HeightRequest="56"
                                CornerRadius="14"
                                BackgroundColor="#FF6A00"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="17"
                                Clicked="OnRegisterClicked" />

                            <Grid ColumnDefinitions="*,Auto,*" Margin="0,8,0,0">

                                <BoxView
                                    HeightRequest="1"
                                    BackgroundColor="#E5EAF2"
                                    VerticalOptions="Center" />

                                <Label
                                    Grid.Column="1"
                                    Text="atau"
                                    Margin="10,0"
                                    TextColor="#9AA7BA" />

                                <BoxView
                                    Grid.Column="2"
                                    HeightRequest="1"
                                    BackgroundColor="#E5EAF2"
                                    VerticalOptions="Center" />

                            </Grid>

                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">

                                <Label
                                    Text="Sudah punya akun?"
                                    FontSize="14"
                                    TextColor="#60708A" />

                                <Button
                                    Text="Login"
                                    BackgroundColor="Transparent"
                                    TextColor="#2563EB"
                                    FontSize="14"
                                    Padding="0"
                                    Clicked="OnOpenLoginClicked" />

                            </HorizontalStackLayout>

                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>

            </Frame>
        </Grid>
    </Grid>
</ContentPage>