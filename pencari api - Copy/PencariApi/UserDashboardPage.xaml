<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PencariApi.UserDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F6F8FC"
    Title="Dashboard User">

    <Grid ColumnDefinitions="250,*" BackgroundColor="#F6F8FC">

        <!-- SIDEBAR -->
        <Grid Grid.Column="0" BackgroundColor="#0D2538" Padding="22,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <HorizontalStackLayout Spacing="12">
                <Frame
    WidthRequest="54"
    HeightRequest="54"
    CornerRadius="16"
    Padding="6"
    HasShadow="False"
    BackgroundColor="Transparent">

                    <Image
        Source="fire_logo.png"
        Aspect="AspectFit"
        HorizontalOptions="Center"
        VerticalOptions="Center"/>
                </Frame>

                <VerticalStackLayout VerticalOptions="Center">
                    <Label
                        Text="PencariApi OPTIMA"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"/>
                    <Label
                        Text="User Report"
                        TextColor="#B8C7D6"
                        FontSize="12"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <VerticalStackLayout Grid.Row="1" Spacing="18" Margin="0,28,0,0">

                <Frame
                    CornerRadius="14"
                    Padding="16,14"
                    HasShadow="False"
                    BackgroundColor="#FF5A14">
                    <HorizontalStackLayout Spacing="14">
                        <Label Text="📍" FontSize="22"/>
                        <Label
                            Text="Lapor Lokasi"
                            TextColor="White"
                            FontSize="15"
                            FontAttributes="Bold"
                            VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Frame>

                <Frame
                    CornerRadius="14"
                    Padding="16,14"
                    HasShadow="False"
                    BackgroundColor="#173B5C">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOpenNlpChatClicked" />
                    </Frame.GestureRecognizers>

                    <HorizontalStackLayout Spacing="14">
                        <Label Text="🤖" FontSize="20"/>
                        <Label
                            Text="NLP Chat"
                            TextColor="White"
                            FontSize="15"
                            FontAttributes="Bold"
                            VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Frame>

            </VerticalStackLayout>

            <Button
                Grid.Row="2"
                Text="Logout"
                HeightRequest="46"
                CornerRadius="12"
                BackgroundColor="#EF4444"
                TextColor="White"
                FontAttributes="Bold"
                Clicked="OnLogoutClicked"/>
        </Grid>

        <!-- CONTENT -->
        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="38,28" Spacing="22">

                <VerticalStackLayout Spacing="4">
                    <Label
                        Text="Laporan Lokasi Kejadian Surabaya"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="#101828"/>

                    <Label
                        Text="Laporkan lokasi kejadian dan buka koordinat langsung ke Google Maps."
                        FontSize="14"
                        TextColor="#667085"/>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="22">

                    <!-- FORM LAPORAN -->
                    <Frame
                        Grid.Column="0"
                        CornerRadius="20"
                        Padding="24"
                        HasShadow="False"
                        BorderColor="#E5EAF2"
                        BackgroundColor="White">

                        <VerticalStackLayout Spacing="14">

                            <Label
                                Text="Form Laporan User"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="#101828"/>

                            <Entry
                                x:Name="NameEntry"
                                Placeholder="Nama pelapor"
                                BackgroundColor="#F9FAFB"
                                TextColor="#101828"/>

                            <Entry
                                x:Name="PhoneEntry"
                                Placeholder="Nomor HP"
                                Keyboard="Telephone"
                                BackgroundColor="#F9FAFB"
                                TextColor="#101828"/>

                            <Entry
                                x:Name="AddressEntry"
                                Placeholder="Alamat kejadian di Surabaya"
                                BackgroundColor="#F9FAFB"
                                TextColor="#101828"/>

                            <Editor
                                x:Name="DetailEditor"
                                Placeholder="Detail kejadian, contoh: asap tebal, api kecil, kabel terbakar..."
                                HeightRequest="110"
                                BackgroundColor="#F9FAFB"
                                TextColor="#101828"/>

                            <Picker
                                x:Name="PriorityPicker"
                                Title="Pilih prioritas"
                                BackgroundColor="#F9FAFB">
                                <Picker.Items>
                                    <x:String>Rendah</x:String>
                                    <x:String>Sedang</x:String>
                                    <x:String>Tinggi</x:String>
                                </Picker.Items>
                            </Picker>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                                <Button
                                    Text="Ambil Lokasi Saya"
                                    HeightRequest="52"
                                    CornerRadius="12"
                                    BackgroundColor="#2563EB"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    Clicked="OnGetLocationClicked"/>

                                <Button
                                    Grid.Column="1"
                                    Text="Buka Lokasi di Maps"
                                    HeightRequest="52"
                                    CornerRadius="12"
                                    BackgroundColor="#0D2538"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    Clicked="OnOpenMyLocationMapClicked"/>
                            </Grid>

                            <Label
                                x:Name="LocationLabel"
                                Text="Lokasi default Surabaya: -7.257500, 112.738100"
                                FontSize="13"
                                TextColor="#667085"/>

                            <Button
                                Text="Kirim Laporan"
                                HeightRequest="56"
                                CornerRadius="14"
                                BackgroundColor="#FF5A14"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="16"
                                Clicked="OnSubmitReportClicked"/>

                        </VerticalStackLayout>
                    </Frame>

                    <!-- INFO POS TERDEKAT -->
                    <Frame
                        Grid.Column="1"
                        CornerRadius="20"
                        Padding="24"
                        HasShadow="False"
                        BorderColor="#E5EAF2"
                        BackgroundColor="White">

                        <VerticalStackLayout Spacing="16">

                            <Label
                                Text="Pos Pemadam Terdekat"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="#101828"/>

                            <Frame
                                CornerRadius="16"
                                Padding="16"
                                HasShadow="False"
                                BackgroundColor="#FFF4EB">

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        x:Name="NearestStationNameLabel"
                                        Text="Belum dihitung"
                                        FontSize="17"
                                        FontAttributes="Bold"
                                        TextColor="#FF5A14"/>

                                    <Label
                                        x:Name="NearestStationAddressLabel"
                                        Text="Ambil lokasi terlebih dahulu."
                                        FontSize="13"
                                        TextColor="#475467"/>

                                    <Label
                                        x:Name="NearestStationDistanceLabel"
                                        Text="Jarak: -"
                                        FontSize="13"
                                        TextColor="#475467"/>
                                </VerticalStackLayout>
                            </Frame>

                            <Button
                                Text="Buka Pos Damkar di Maps"
                                HeightRequest="52"
                                CornerRadius="12"
                                BackgroundColor="#12B76A"
                                TextColor="White"
                                FontAttributes="Bold"
                                Clicked="OnOpenNearestStationMapClicked"/>

                            <BoxView HeightRequest="1" BackgroundColor="#E5EAF2"/>

                            <Label
                                Text="Riwayat Laporan Saya"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="#101828"/>

                            <CollectionView
                                x:Name="MyReportsCollection"
                                HeightRequest="280"
                                SelectionMode="Single"
                                SelectionChanged="OnMyReportSelected">

                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Frame
                                            Margin="0,6"
                                            Padding="14"
                                            CornerRadius="14"
                                            HasShadow="False"
                                            BorderColor="#E5EAF2"
                                            BackgroundColor="#F9FAFB">

                                            <VerticalStackLayout Spacing="4">
                                                <Label
                                                    Text="{Binding Address}"
                                                    FontAttributes="Bold"
                                                    TextColor="#101828"
                                                    FontSize="14"/>

                                                <Label
                                                    Text="{Binding Detail}"
                                                    TextColor="#475467"
                                                    FontSize="12"/>

                                                <Label
                                                    Text="{Binding Status}"
                                                    TextColor="#2563EB"
                                                    FontAttributes="Bold"
                                                    FontSize="12"/>

                                                <Label
                                                    Text="{Binding NearestStationName}"
                                                    TextColor="#FF5A14"
                                                    FontSize="12"/>
                                            </VerticalStackLayout>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Button
                                Text="Buka Laporan Terpilih di Maps"
                                HeightRequest="52"
                                CornerRadius="12"
                                BackgroundColor="#2563EB"
                                TextColor="White"
                                FontAttributes="Bold"
                                Clicked="OnOpenSelectedReportMapClicked"/>

                        </VerticalStackLayout>
                    </Frame>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>