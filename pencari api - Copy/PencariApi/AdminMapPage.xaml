<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PencariApi.AdminMapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F6F8FC"
    Title="Peta Rute Admin">

    <Grid RowDefinitions="90,*" Padding="24" RowSpacing="16">

        <!-- HEADER -->
        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">

            <VerticalStackLayout>
                <Label
                    Text="Peta Rute Laporan Kebakaran"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#101828" />

                <Label
                    Text="Admin dapat melihat lokasi laporan user dan rute paling efektif dari pos pemadam terdekat."
                    FontSize="14"
                    TextColor="#667085" />
            </VerticalStackLayout>

            <Button
                Grid.Column="1"
                Text="Refresh"
                WidthRequest="110"
                HeightRequest="48"
                CornerRadius="12"
                BackgroundColor="#2563EB"
                TextColor="White"
                FontAttributes="Bold"
                Clicked="OnRefreshClicked" />

            <Button
                Grid.Column="2"
                Text="Buka Browser"
                WidthRequest="140"
                HeightRequest="48"
                CornerRadius="12"
                BackgroundColor="#12B76A"
                TextColor="White"
                FontAttributes="Bold"
                Clicked="OnOpenBrowserClicked" />

            <Button
                Grid.Column="3"
                Text="Dashboard"
                WidthRequest="130"
                HeightRequest="48"
                CornerRadius="12"
                BackgroundColor="#FF5A14"
                TextColor="White"
                FontAttributes="Bold"
                Clicked="OnBackDashboardClicked" />

        </Grid>

        <!-- BODY -->
        <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="16">

            <!-- SIDEBAR DATA LAPORAN -->
            <Frame
                Grid.Column="0"
                Padding="18"
                CornerRadius="18"
                HasShadow="False"
                BackgroundColor="White"
                BorderColor="#E5EAF2">

                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Daftar Laporan"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#101828" />

                        <Label
                            x:Name="ReportCountLabel"
                            Text="0 laporan tersedia"
                            FontSize="13"
                            TextColor="#667085" />
                    </VerticalStackLayout>

                    <BoxView
                        Grid.Row="1"
                        HeightRequest="1"
                        Color="#E5EAF2" />

                    <CollectionView
                        x:Name="ReportsCollection"
                        Grid.Row="2"
                        SelectionMode="Single"
                        SelectionChanged="OnReportSelected">

                        <CollectionView.EmptyView>
                            <VerticalStackLayout
                                Padding="20"
                                Spacing="10"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">

                                <Label
                                    Text="Belum ada laporan"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="#667085"
                                    HorizontalTextAlignment="Center" />

                                <Label
                                    Text="Laporan dari user akan tampil di sini."
                                    FontSize="13"
                                    TextColor="#98A2B3"
                                    HorizontalTextAlignment="Center" />

                            </VerticalStackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame
                                    Margin="0,6"
                                    Padding="14"
                                    CornerRadius="14"
                                    HasShadow="False"
                                    BackgroundColor="#FAFBFD"
                                    BorderColor="#DCE4EF">

                                    <VerticalStackLayout Spacing="6">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label
                                                Grid.Column="0"
                                                Text="{Binding ReporterName}"
                                                FontSize="15"
                                                FontAttributes="Bold"
                                                TextColor="#101828" />

                                            <Frame
                                                Grid.Column="1"
                                                Padding="8,3"
                                                CornerRadius="8"
                                                HasShadow="False"
                                                BackgroundColor="#FFF4EB">

                                                <Label
                                                    Text="{Binding Priority}"
                                                    FontSize="11"
                                                    FontAttributes="Bold"
                                                    TextColor="#FF5A14" />
                                            </Frame>
                                        </Grid>

                                        <Label
                                            Text="{Binding Address}"
                                            FontSize="13"
                                            TextColor="#475467"
                                            LineBreakMode="TailTruncation" />

                                        <Label
                                            Text="{Binding NearestStationName}"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            TextColor="#12B76A"
                                            LineBreakMode="TailTruncation" />

                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label
                                                Grid.Column="0"
                                                Text="{Binding Status}"
                                                FontSize="12"
                                                TextColor="#2563EB" />

                                            <Label
                                                Grid.Column="1"
                                                Text="{Binding DistanceKm, StringFormat='{0:F2} km'}"
                                                FontSize="12"
                                                TextColor="#667085" />
                                        </Grid>

                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button
                        Grid.Row="3"
                        Text="Lihat Rute Terpilih"
                        HeightRequest="48"
                        CornerRadius="12"
                        BackgroundColor="#0F2742"
                        TextColor="White"
                        FontAttributes="Bold"
                        Clicked="OnShowSelectedRouteClicked" />

                </Grid>
            </Frame>

            <!-- MAP DAN DETAIL -->
            <Grid Grid.Column="1" RowDefinitions="190,*" RowSpacing="16">

                <!-- DETAIL RUTE -->
                <Frame
                    Grid.Row="0"
                    Padding="18"
                    CornerRadius="18"
                    HasShadow="False"
                    BackgroundColor="White"
                    BorderColor="#E5EAF2">

                    <Grid ColumnDefinitions="1.2*,1*,1*" ColumnSpacing="16">

                        <VerticalStackLayout Spacing="8">

                            <Label
                                Text="Detail Laporan"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="#101828" />

                            <Label
                                x:Name="SelectedReportTitleLabel"
                                Text="Pilih salah satu laporan"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="#FF5A14" />

                            <Label
                                x:Name="ReporterLabel"
                                Text="Pelapor: -"
                                FontSize="13"
                                TextColor="#475467" />

                            <Label
                                x:Name="PhoneLabel"
                                Text="Telepon: -"
                                FontSize="13"
                                TextColor="#475467" />

                            <Label
                                x:Name="PriorityLabel"
                                Text="Prioritas: -"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="#2563EB" />

                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="8">

                            <Label
                                Text="Lokasi Kejadian"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="#101828" />

                            <Label
                                x:Name="AddressLabel"
                                Text="Alamat: -"
                                FontSize="13"
                                TextColor="#475467" />

                            <Label
                                x:Name="CoordinateLabel"
                                Text="Koordinat: -"
                                FontSize="13"
                                TextColor="#475467" />

                            <Label
                                x:Name="DetailLabel"
                                Text="Detail: -"
                                FontSize="13"
                                TextColor="#475467"
                                LineBreakMode="TailTruncation" />

                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" Spacing="8">

                            <Label
                                Text="Rute Efektif"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="#101828" />

                            <Label
                                x:Name="StationNameLabel"
                                Text="Pos Damkar: -"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="#12B76A" />

                            <Label
                                x:Name="StationAddressLabel"
                                Text="Alamat Pos: -"
                                FontSize="13"
                                TextColor="#475467"
                                LineBreakMode="TailTruncation" />

                            <Label
                                x:Name="DistanceLabel"
                                Text="Jarak: -"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="#FF5A14" />

                            <Label
                                x:Name="RouteInfoLabel"
                                Text="Rute akan tampil setelah laporan dipilih."
                                FontSize="12"
                                TextColor="#667085" />

                        </VerticalStackLayout>

                    </Grid>
                </Frame>

                <!-- GOOGLE MAPS WEBVIEW -->
                <Frame
                    Grid.Row="1"
                    Padding="0"
                    CornerRadius="18"
                    IsClippedToBounds="True"
                    HasShadow="False"
                    BackgroundColor="White"
                    BorderColor="#E5EAF2">

                    <Grid>

                        <WebView
                            x:Name="WebMap"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill" />

                        <Frame
                            x:Name="MapLoadingFrame"
                            Padding="20"
                            CornerRadius="14"
                            HasShadow="False"
                            BackgroundColor="#F9FAFB"
                            BorderColor="#E5EAF2"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                            <VerticalStackLayout Spacing="8">

                                <ActivityIndicator
                                    x:Name="MapLoadingIndicator"
                                    IsRunning="True"
                                    Color="#FF5A14"
                                    WidthRequest="40"
                                    HeightRequest="40" />

                                <Label
                                    Text="Memuat Google Maps..."
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    TextColor="#475467"
                                    HorizontalTextAlignment="Center" />

                            </VerticalStackLayout>
                        </Frame>

                    </Grid>
                </Frame>

            </Grid>
        </Grid>
    </Grid>
</ContentPage>